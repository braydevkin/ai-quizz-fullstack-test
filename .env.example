# ---------------------------------------------------------------------------
# Copy this file to `.env` at the repository root: cp .env.example .env
# It is consumed by the API (local dev) and by docker compose.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
POSTGRES_USER=quiz
POSTGRES_PASSWORD=quiz
POSTGRES_DB=quiz
POSTGRES_PORT=5432

# Local development (Postgres exposed on the host)
DATABASE_URL=postgresql://quiz:quiz@localhost:5432/quiz

# --- API ------------------------------------------------------------------
PORT=3333
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# --- Web ------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3333
