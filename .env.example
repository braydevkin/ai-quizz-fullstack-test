# ---------------------------------------------------------------------------
# Copy this file to `.env` at the repository root: cp .env.example .env
#
# `.env` is read by the API at boot (validated with zod in
# `apps/api/src/lib/env.ts`) and by `docker compose` for interpolation. It is
# gitignored — never commit it, and never put a real secret in THIS file.
#
# This is a blank template on purpose: no credential has a value here, and none
# has a fallback in `docker-compose.yml` either. Fill it in for local
# development; outside it, inject the values through the environment (CI
# secrets, deploy platform, secret manager).
#
# Variables left empty are treated as unset, so the ones marked optional below
# fall back to the default shown in brackets.
#
# Keep comments on their own line: `docker compose` does not strip a trailing
# `# …` from an otherwise empty assignment, it reads it as the value.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------

# Required. Compose refuses to start when any of the three is empty rather than
# falling back to a well-known user/password. Keep them URL-safe: they are
# interpolated into the API container's DATABASE_URL.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Optional [5432]. Host port the compose Postgres is published on.
POSTGRES_PORT=

# Required by the API. Used when it runs on the host (`pnpm dev`), where
# Postgres is on localhost:
#   postgresql://<user>:<password>@localhost:5432/<db>
# Inside compose the API gets its own DATABASE_URL, assembled from the
# POSTGRES_* variables above and pointing at the `postgres` service instead.
DATABASE_URL=

# --- API ------------------------------------------------------------------

# Optional [3333].
PORT=

# Optional [0.0.0.0].
HOST=

# Optional [development]. development | test | production
NODE_ENV=

# Optional [info]. fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=

# Optional [http://localhost:3000]. Comma-separated origins, or `*`.
CORS_ORIGIN=

# --- Web ------------------------------------------------------------------

# Optional [http://localhost:3333]. Inlined into the browser bundle at build
# time, so it must be reachable from the host — not `http://api:3333`.
NEXT_PUBLIC_API_URL=
