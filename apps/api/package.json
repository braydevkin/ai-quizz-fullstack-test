{
  "name": "@quiz/api",
  "version": "0.2.0",
  "private": true,
  "description": "Express + Kysely backend for the AI Development Quiz App",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "clean": "rm -rf dist coverage .turbo *.tsbuildinfo",
    "db:migrate": "tsx src/db/migrate.ts latest",
    "db:migrate:up": "tsx src/db/migrate.ts up",
    "db:migrate:down": "tsx src/db/migrate.ts down",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@quiz/shared": "workspace:*",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "kysely": "0.29.4",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@quiz/config": "workspace:*",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "eslint": "9.39.5",
    "jest": "30.4.2",
    "pino-pretty": "13.1.3",
    "ts-jest": "29.4.12",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
