{
  "name": "ai-quiz-app",
  "version": "0.1.0",
  "private": true,
  "description": "AI Development Quiz App — monorepo infrastructure (pnpm workspaces + Turborepo)",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}\"",
    "clean": "turbo run clean",
    "db:migrate": "pnpm --filter @quiz/api db:migrate",
    "db:migrate:up": "pnpm --filter @quiz/api db:migrate:up",
    "db:migrate:down": "pnpm --filter @quiz/api db:migrate:down",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "prepare": "cd .. && husky quizapp-fullstack-test/.husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@quiz/config": "workspace:*",
    "husky": "9.1.7",
    "lint-staged": "17.2.0",
    "prettier": "3.9.6",
    "turbo": "2.10.6",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
