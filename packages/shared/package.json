{
  "name": "@quiz/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Code shared between the API and the web app: types, schemas, constants and utils",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@quiz/config": "workspace:*",
    "@types/node": "22.20.1",
    "eslint": "9.39.5",
    "typescript": "5.9.3"
  }
}
