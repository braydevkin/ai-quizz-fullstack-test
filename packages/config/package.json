{
  "name": "@quiz/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript / ESLint / Prettier configuration consumed by every workspace",
  "type": "module",
  "files": [
    "tsconfig",
    "eslint",
    "jest",
    "prettier"
  ],
  "exports": {
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/nextjs.json": "./tsconfig/nextjs.json",
    "./eslint/base": "./eslint/base.mjs",
    "./eslint/node": "./eslint/node.mjs",
    "./eslint/next": "./eslint/next.mjs",
    "./jest/base": "./jest/base.mjs",
    "./jest/node": "./jest/node.mjs",
    "./jest/react": "./jest/react.mjs",
    "./prettier": "./prettier/index.mjs"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "echo \"@quiz/config: no TypeScript sources to check\"",
    "clean": "rm -rf .turbo node_modules"
  },
  "dependencies": {
    "@eslint/js": "9.39.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-next": "16.2.11",
    "globals": "17.7.0",
    "prettier-plugin-tailwindcss": "0.8.1",
    "typescript-eslint": "8.65.0"
  },
  "devDependencies": {
    "eslint": "9.39.5",
    "prettier": "3.9.6",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=3",
    "typescript": ">=5"
  }
}
